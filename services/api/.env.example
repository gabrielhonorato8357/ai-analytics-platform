APP_ENV=development
APP_NAME=ai-analytics-api
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://analytics:analytics_password@localhost:5432/analytics_platform
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000
JWT_SECRET_KEY=change-me-in-production-32-byte-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=30
AI_SQL_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
MAX_QUERY_ROWS=500
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-me-admin-password
FIRST_SUPERUSER_NAME=Platform Administrator
